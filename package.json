{
  "name": "ibia",
  "version": "1.0.0",
  "main": "main.js",
  "description": "A lightweight desktop AI assistant with local and cloud model support.",
  "author": "Mark Chweya",
  "scripts": {
    "start": "npx electron .",
    "site": "npm --prefix website run dev",
    "site:build": "npm --prefix website run build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "30.0.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.markchweya.ibia",
    "productName": "ibia",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "style.css",
      "package.json",
      "scripts/extract_assets.py",
      "build/icon.ico",
      "!**/.env",
      "!**/.env.*",
      "!dist/**",
      "!website/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "ibia"
    },
    "publish": null
  }
}
